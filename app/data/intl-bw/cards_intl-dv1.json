      "en": "First Ticket",
      "fr": "Ticket Prioritaire"
    },
    "pokemon": [],
    "illustrator": "5ban Graphics",
    "rarity": "rare",
    "regulation_mark": null,
    "variants": [
      {
        "id": "normal",
        "images": {
          "de": "",
          "en": "/images/cards/intl-dv1/en/19.webp",
